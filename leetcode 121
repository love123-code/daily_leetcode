class Solution {
    public int maxProfit(int[] prices) {
        int profit=0;
        int minimum=prices[0];
        for(int i=1;i<prices.length;i++){
            if(minimum > prices[i]){
                minimum=prices[i];
            }
            if(profit<(prices[i]-minimum)){
                profit=prices[i]-minimum;
            }
        }
        return profit;
        
    }
}